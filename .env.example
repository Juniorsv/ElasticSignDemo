# ============================================================
#  Gases del Oriente - Elastic Signing Demo (Docusign Click API)
#  Copia este archivo como .env y completa los valores.
# ============================================================

# ---- Entorno de Docusign ----
# Developer (demo):   https://demo.docusign.net   +   https://account-d.docusign.com
# Producción:         https://www.docusign.net    +   https://account.docusign.com
DS_ENV=https://demo.docusign.net
DS_OAUTH_BASE=https://account-d.docusign.com

# ---- Credenciales JWT Grant (Integration Key) ----
# Integration Key (Client ID) de tu app JWT en Docusign
DS_INTEGRATION_KEY=00000000-0000-0000-0000-000000000000

# User ID (API Username / GUID) del usuario que se impersona
DS_USER_ID=00000000-0000-0000-0000-000000000000

# API Account ID (GUID) de la cuenta Docusign
DS_ACCOUNT_ID=00000000-0000-0000-0000-000000000000

# Clave privada RSA.
# OPCIÓN A (recomendada para Render): pega la clave completa en una sola variable,
#   con saltos de línea reales (Render soporta multilínea) o usando \n escapados.
DS_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIE...\n-----END RSA PRIVATE KEY-----"
# OPCIÓN B (local): deja DS_PRIVATE_KEY vacío y usa un archivo en disco.
DS_PRIVATE_KEY_PATH=./private.key

# ---- IDs de los dos Elastic Signing agreements (clickwraps) ----
# Se generan al correr `npm run create-agreements`. Cópialos aquí después.
CLICKWRAP_ID_PROMESA=
CLICKWRAP_ID_PAGARE=

# ---- Servidor ----
PORT=3000
